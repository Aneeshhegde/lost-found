# Server Configuration
PORT=5000

# MongoDB Connection
mongoURI=mongodb://localhost:27017/your-database-name
# For MongoDB Atlas: mongoURI=mongodb+srv://username:password@cluster.mongodb.net/database-name

# JWT Secret Key
SECRETKEY=your-secret-key-here

# Email Configuration (Gmail)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-digit-app-password

# Instructions:
# 1. Copy this file and rename it to .env
# 2. Replace all placeholder values with your actual credentials
# 3. NEVER commit the .env file to Git
# 4. For Gmail App Password, visit: https://myaccount.google.com/apppasswords
